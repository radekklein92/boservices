# Upstash Redis (pro ukládání leadů z kontaktního formuláře)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (e-mailová notifikace o novém leadu)
RESEND_API_KEY=
NOTIFY_EMAIL=klein@wearetwist.com
FROM_EMAIL="BOServices <noreply@boservices.cz>"

# Honeypot - skrytá pole, která by skutečný uživatel nikdy nevyplnil
NEXT_PUBLIC_SITE_URL=https://boservices.cz

# ─── PORTÁL (Fáze 1: auth foundation) ─────────────────────────
# NextAuth v5 - session secret (vyrob: openssl rand -base64 32)
AUTH_SECRET=
# Čárkou oddělené e-maily, které dostanou roli superadmin při prvním přihlášení
PORTAL_SUPERADMIN_EMAILS=klein.radek@seznam.cz
# Vercel Blob token (pro Fázi 5 - generování PDF a upload skenů)
BLOB_READ_WRITE_TOKEN=
# Volitelně - URL pro download chromium-min binárky (pro PDF generaci na Vercelu)
# CHROMIUM_PACK_URL=

# ─── Synchronizace lokalit z Transition ───────────────────────
# Read-only endpoint v Transition + sdílený token (stejná hodnota jako
# BOSERVICES_SYNC_TOKEN v Transition). Bez nich je sync čistý no-op.
# Stejný token chrání i náš protisměrný endpoint /api/public/contracts,
# ze kterého si Transition stahuje podepsané franšízingové smlouvy.
TRANSITION_LOCATIONS_URL=https://transition.wearetwist.com/api/public/locations
TRANSITION_API_TOKEN=
# Bearer token pro Vercel cron (chrání /api/cron/locations-sync i ostatní crony)
CRON_SECRET=

# ─── Zrcadlení pohledávek z ClamoraPortal ─────────────────────
# Read-only endpoint v ClamoraPortal + sdílený token (stejná hodnota jako
# CLAMORA_PUBLIC_TOKEN v ClamoraPortal). Bez nich je sync čistý no-op.
# Zrcadlí postoupené pohledávky podepsané klientem do dlaždice „Postoupené
# pohledávky" (stejný pattern jako sync lokalit z Transition výše).
CLAMORA_CLAIMS_URL=https://portal.clamorabridge.cz/api/public/claims
CLAMORA_PUBLIC_TOKEN=

# ─── DigiSign (elektronický podpis - zatím jen NDA) ───────────
# Samostatný DigiSign účet pro BOServices. Prod base URL: https://api.digisign.org
DIGISIGN_ACCESS_KEY=
DIGISIGN_SECRET_KEY=
DIGISIGN_BASE_URL=https://api.digisign.org
# Volitelné: branding obálky (UUID, ne IRI)
DIGISIGN_BRANDING_ID=
# Tajný klíč pro ověření webhooku (předává se jako ?secret=… v URL webhooku
# zaregistrované v DigiSign adminu: /api/portal/digisign/webhook?secret=…)
DIGISIGN_WEBHOOK_SECRET=

# ─── Telegram (check-in stavu lokalit pro RE agenty) ──────────
# Bot token z @BotFather. Bez něj je digest cron i webhook čistý no-op.
TELEGRAM_BOT_TOKEN=
# Tajný token pro ověření webhooku. Předává se jako secret_token při setWebhook;
# Telegram ho pak posílá v hlavičce X-Telegram-Bot-Api-Secret-Token na
# /api/telegram/webhook. Digest jezdí přes cron 0 6 * * 2,4 (út+čt), mapování
# agent -> chat_id skupiny se spravuje v adminu (/portal/admin/telegram).
TELEGRAM_WEBHOOK_SECRET=

# ─── SSO do DW dashboardu (odkazy Clouds + API keys v adminu) ──
# Sdílený secret s dw.boservices.cz - MUSÍ se shodovat se SSO_SECRET v DW
# dashboardu. Portál razí krátkodobý handoff token, dashboard ho ověří a vystaví
# vlastní session → admin se dostane na /clouds + /settings/api-keys bez druhého
# loginu. Bez SSO_SECRET odkaz jen vede na dashboard (kde se přihlásí ručně).
SSO_SECRET=
# Base URL DW dashboardu (default https://dw.boservices.cz)
DW_BASE=https://dw.boservices.cz

# ─── Konzole změn (admin: /portal/admin/changes) ──────────────
# JEDINÉ povinné: fine-grained PAT na repo boservices: Issues (Read/Write);
# Pull requests, Contents, Deployments, Checks, Metadata (Read-only). Bez něj je
# konzole no-op (stránka funguje, odeslání hlásí "nenakonfigurováno").
GITHUB_BOT_TOKEN=
# Volitelné (default radekklein92/boservices; nastav jen při přesunu repa):
# GITHUB_OWNER=radekklein92
# GITHUB_REPO=boservices
# Volitelné: příjemci e-mailu po PRODUKČNÍM nasazení (default = PORTAL_SUPERADMIN_EMAILS).
# DEPLOY_NOTIFY_TO=klein@wearetwist.com
# Volitelně: DEPLOY_NOTIFY_ALL=1 = e-mail u VŠECH produkčních nasazení
# (default jen u nasazení pocházejících z Portálu).
# DEPLOY_NOTIFY_ALL=
#
# Pozn.: GitHub Actions secrets se NEdávají sem, ale na repo přes `gh secret set`:
#   ANTHROPIC_API_KEY  - pro Claude Code Action (.github/workflows/claude.yml)
#   CRON_SECRET        - aby deploy-notify.yml mohl volat /api/portal/internal/notify-deploy
